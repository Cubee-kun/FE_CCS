# ✅ API Configuration
VITE_API_MODE=auto
VITE_API_URL_LOCAL=http://127.0.0.1:8000/api
VITE_API_URL_PRODUCTION=https://apibeccs.nexcube-digital.com/api
# Optional direct override
# VITE_API_URL=http://localhost:8000/api

# ✅ Blockchain Configuration (Sepolia Testnet)
VITE_CONTRACT_ADDRESS=0x5C5F6CE61647600bB8c04F59c0F2B493EBE78DDF

# ✅ PRIMARY RPC (use reliable free provider)
VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ✅ BACKUP RPC (set if you have Infura/Alchemy account)
# VITE_SEPOLIA_RPC_BACKUP=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# ✅ Polygon Amoy / Infura API
# VITE_INFURA_API_SECRET=your_infura_api_secret
# VITE_POLYGON_RPC_URL=https://polygon-amoy.infura.io/v3/YOUR_PROJECT_ID
# VITE_INFURA_GAS_API_URL=https://gas.api.infura.io/v3/YOUR_PROJECT_ID

# ✅ Wallet Configuration (NEVER commit private keys!)
# VITE_WALLET_ADDRESS=0xYourWalletAddressHere
# VITE_WALLET_PRIVATE_KEY=your_private_key_here

# ✅ Rate Limiting Configuration
VITE_MIN_REQUEST_INTERVAL=1000
VITE_MAX_CONCURRENT_REQUESTS=3
